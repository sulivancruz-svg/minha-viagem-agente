{
  "version": 2,
  "builds": [
    {
      "src": "packages/dashboard/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "packages/dashboard/$1"
    }
  ],
  "env": {
    "DATABASE_URL": "@database_url",
    "NEXT_PUBLIC_API_URL": "@next_public_api_url",
    "NEXT_PUBLIC_AUTH_SECRET": "@next_public_auth_secret"
  }
}
