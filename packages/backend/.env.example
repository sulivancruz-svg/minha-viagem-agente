# ============================================================
# Backend - Variáveis de Ambiente
# Copie para .env e preencha com valores reais
# ============================================================

# BANCO DE DADOS
# Desenvolvimento (SQLite): DATABASE_URL="file:./dev.db"
# Produção (PostgreSQL): DATABASE_URL="postgresql://user:pass@host:5432/db"
# Produção (Supabase): DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_ID].supabase.co:5432/postgres"
DATABASE_URL="file:./dev.db"

# AUTENTICAÇÃO JWT
JWT_SECRET="sua-chave-secreta-longa-e-aleatoria-minimo-32-caracteres"
JWT_EXPIRES_IN="7d"

# SERVIDOR
PORT=3001
NODE_ENV="development"

# CORS - Origens permitidas (separe com vírgula)
# Produção: CORS_ORIGINS="https://vendamaisviagens.com.br,https://dashboard.vendamaisviagens.com.br"
CORS_ORIGINS="http://localhost:3000,http://localhost:3005,http://localhost:3001,chrome-extension://*"

# CRIPTOGRAFIA (AES-256, 32 bytes em formato hex = 64 caracteres)
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

# DASHBOARD URL (para links em notificações e redirects)
DASHBOARD_URL="http://localhost:3005"

# LOGS
LOG_LEVEL="info"

# ============================================================
# OPCIONAL: Variáveis para integração com serviços externos
# ============================================================

# IA/LLM (descomente e preencha se usar)
# OPENAI_API_KEY="sk_..."
# ANTHROPIC_API_KEY="sk-ant-..."

# EMAIL SMTP (descomente se implementar envio de emails)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="seu_email@gmail.com"
# SMTP_PASS="sua_senha_ou_app_password"
# SMTP_FROM="noreply@vendamaisviagens.com.br"

# ARMAZENAMENTO S3 (descomente se implementar uploads em S3/R2)
# AWS_ACCESS_KEY_ID="..."
# AWS_SECRET_ACCESS_KEY="..."
# AWS_REGION="us-east-1"
# AWS_BUCKET_NAME="minha-viagem-agente"
# AWS_S3_ENDPOINT="https://s3.amazonaws.com"

# API OFICIAL WHATSAPP BUSINESS (se não usar Web.js)
# WHATSAPP_BUSINESS_PHONE_NUMBER_ID="..."
# WHATSAPP_BUSINESS_ACCOUNT_ID="..."
# WHATSAPP_BUSINESS_ACCESS_TOKEN="..."
# WHATSAPP_WEBHOOK_VERIFY_TOKEN="seu_token_verificacao"

# POOL DE CONEXÃO DO BANCO (PostgreSQL)
# DATABASE_POOL_MIN="2"
# DATABASE_POOL_MAX="10"
# DATABASE_POOL_TIMEOUT="3000"
